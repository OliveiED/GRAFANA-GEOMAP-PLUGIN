          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\nsubstring(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace(replace\r\n(it.name, 'Onlines ', ''),'Autorizadas ', ''),'Offlines ', ''),': Tx Power', ''),': Temperatura', ''),': Bias', ''),': Tipo', ''),': Voltagem', ''),': Laser', '')\r\n,'(): Bits sent', ''),'(): Bits received', ''),'Interface', 'PON'), 1)\r\nAS itemname,\r\nMAX(CASE WHEN itg.value LIKE '%ONUs Autorizadas%' THEN hu.value END) AS \"Autorizadas\",\r\nMAX(CASE WHEN itg.value LIKE '%ONUs ON%' THEN hu.value END) AS \"Onlines\",\r\nMAX(CASE WHEN itg.value LIKE '%ONUs OFF%' THEN hu.value END) AS \"Offlines\",\r\nMAX(CASE WHEN itg.value LIKE '%PON Status%' THEN hu.value END) AS \"Status\",\r\nMAX(CASE WHEN it.name LIKE '%Bits sent%' THEN hu.value END) AS \"Bits In\",\r\nMAX(CASE WHEN it.name LIKE '%Bits received%' THEN hu.value END) AS \"Bits Out\",\r\n#MAX(CASE WHEN itg.tag LIKE '%PON Tx Power%' THEN h.value END) AS \"Tx Power\",\r\n#MAX(CASE WHEN itg.tag LIKE '%PON Bias%' THEN h.value END) AS \"Bias\",\r\n#MAX(CASE WHEN itg.tag LIKE '%PON Laser%' THEN hu.value END) AS \"Laser\",\r\nMAX(CASE WHEN itg.tag LIKE '%PON Temperatura%' THEN hu.value END) AS \"Temperatura\",\r\n#MAX(CASE WHEN itg.tag LIKE '%PON Tipo%' THEN h.value END) AS \"Tipo\",\r\n#MAX(CASE WHEN itg.tag LIKE '%PON Voltagem%' THEN h.value END) AS \"Voltagem\",\r\nDATE_FORMAT(CONVERT_TZ(FROM_UNIXTIME(max(max_clock)), '+03:00', '+03:00'), '%d-%m-%Y %H:%i:%s') AS \"Ultima Verificacao\"\r\nFROM\r\nitems it\r\nINNER JOIN hosts ht ON (it.hostid = ht.hostid and ht.name like '%$host%')\r\nLEFT JOIN (SELECT hu.itemid, MAX(hu.clock) AS max_clock FROM history_uint hu GROUP BY hu.itemid) max_hu ON (it.itemid = max_hu.itemid)\r\nLEFT JOIN history_uint hu ON (max_hu.itemid = hu.itemid AND max_hu.max_clock = hu.clock)\r\nLEFT JOIN (SELECT h.itemid, MAX(h.clock) AS max_clock_h FROM history h GROUP BY h.itemid) max_h ON (it.itemid = max_h.itemid)\r\nLEFT JOIN history h ON (max_h.itemid = h.itemid AND max_h.max_clock_h = h.clock)\r\nLEFT JOIN item_tag itg ON (itg.itemid = it.itemid)\r\nWHERE\r\nht.name LIKE \"%$host%\"\r\nAND it.name LIKE '%PON GPON%' or it.name LIKE '%Interface GPON%'\r\nGROUP BY\r\nitemname\r\nORDER BY\r\nSUBSTRING_INDEX(itemname, ' ', -3) + 0,\r\nSUBSTRING_INDEX(SUBSTRING_INDEX(itemname, ' ', -2), '/', -2) + 0,\r\nSUBSTRING_INDEX(SUBSTRING_INDEX(itemname, ' ', -1), '/', -1) + 0;\r\n",

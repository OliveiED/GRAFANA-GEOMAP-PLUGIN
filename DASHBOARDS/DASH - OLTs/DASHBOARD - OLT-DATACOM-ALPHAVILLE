n        color: color // Cor da linha\n      },\n      showSymbol: false,\n      areaStyle: {\n        opacity: 0.2,\n        color: color // Cor do preenchimento (mesma cor da linha)\n      },\n      emphasis: {\n        focus: 'series'\n      },\n      data: data\n    });\n  });\n});\n\nconst commonUnit = getCommonUnit(seriesData);\n\nreturn {\n  color: seriesData.map(() => getRandomColor()),\n  tooltip: {\n    trigger: 'axis',\n    axisPointer: {\n      type: 'cross',\n      label: {\n        backgroundColor: '#1A1E24'\n      }\n    },\n    formatter: function (params) {\n      let tooltipText = '';\n      params.forEach(param => {\n        const seriesName = param.seriesName;\n        const dataIndex = param.dataIndex;\n        const data = seriesData.find(s => s.name === seriesName).data[dataIndex];\n        const formatted = formatDataValue(data);\n        tooltipText += `${seriesName}: ${formatted.value} ${formatted.unit}<br/>`;\n      });\n      return tooltipText;\n    }\n  },\n  legend: {\n    data: seriesData.map(s => s.name),\n    textStyle: {\n      color: '#fff',\n      fontSize: 14\n    },\n    itemWidth: 20,\n    itemHeight: 14\n  },\n  toolbox: {\n    orient: 'vertical',\n    left: 'right',\n    top: 'center',\n    feature: {\n      saveAsImage: {}\n    }\n  },\n  grid: {\n    left: '5%',\n    right: '5%',\n    bottom: '5%',\n    containLabel: true\n  },\n  xAxis: [{\n    type: 'category',\n    boundaryGap: false,\n    data: timeLabels,\n    axisLine: {\n      lineStyle: {\n        color: '#fff',\n        width: 2\n      }\n    },\n    axisLabel: {\n      textStyle: {\n        color: '#fff',\n        fontSize: 12\n      }\n    },\n    splitLine: {\n      show: false\n    }\n  }],\n  yAxis: [{\n    type: 'value',\n    axisLine: {\n      lineStyle: {\n        color: '#fff',\n        width: 2\n      }\n    },\n    axisLabel: {\n      formatter: formatYAxisLabel,\n      textStyle: {\n        color: '#fff',\n        fontSize: 14\n      }\n    },\n    splitLine: {\n      show: true,\n      lineStyle: {\n        color: '#444',\n        type: 'dashed'\n      }\n    }\n  }],\n  series: seriesData,\n  backgroundColor: 'transparent', // Cor de fundo escura\n  title: {\n    text: 'Análise de Uso de Banda',\n    left: 'center',\n    top: '20px',\n    textStyle: {\n      color: '#fff',\n      fontSize: 0\n    }\n  },\n  animationDuration: 1500, // Animação suave\n  animationEasing: 'elasticOut' // Efeito de animação\n};\n",

        "html": "<div class=\"soc-panel\">\n  <div class=\"soc-header\">\n    <div>\n      <div class=\"soc-title\">Top 10 Destinations</div>\n      <div class=\"soc-subtitle\">Últimos 5 minutos • DNS destination overview</div>\n    </div>\n    <div class=\"soc-pill\">SOC MONITORING</div>\n  </div>\n\n  <div class=\"soc-table-wrap\">\n    <table class=\"soc-table\">\n      <thead>\n        <tr>\n          <th class=\"col-rank\">Rank</th>\n          <th class=\"col-source\">Destinos</th>\n          <th class=\"col-req\">Requisições</th>\n        </tr>\n      </thead>\n      <tbody id=\"tbody-destinos\">\n        <tr>\n          <td colspan=\"3\" class=\"loading-cell\">Carregando dados...</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",

        "css": "/* Container Principal */\n#system-overview-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n\n    /* Fundo no mesmo estilo do TOP 10 Destinations */\n    background:\n        radial-gradient(circle at top right, rgba(0, 140, 255, 0.10), transparent 35%),\n        radial-gradient(circle at bottom left, rgba(0, 80, 180, 0.08), transparent 30%),\n        linear-gradient(180deg, #09111f 0%, #060d18 100%);\n\n    border: 1px solid rgba(80, 140, 255, 0.12);\n    box-shadow:\n        inset 0 0 30px rgba(0, 140, 255, 0.05),\n        0 0 12px rgba(0, 0, 0, 0.25);\n\n    border-radius: 12px;\n    overflow: hidden;\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #dbe7ff;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid rgba(120, 170, 255, 0.12);\n    flex-shrink: 0;\n}\n\n.panel-title i {\n    color: #7ea6ff;\n    font-size: 1.2em;\n}\n\n/* Wrapper para Layout de 2 Colunas */\n.main-content-wrapper {\n    display: flex;\n    flex-grow: 1;\n    gap: 20px;\n    overflow: hidden;\n    min-height: 0;\n}\n\n/* Coluna da Esquerda (Logo) */\n.logo-column {\n    flex-basis: 200px;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 10px;\n}\n\n.logo-column img {\n    max-width: 100%;\n    max-height: 150px;\n    height: auto;\n    object-fit: contain;\n    filter: drop-shadow(0 0 12px rgba(0, 180, 255, 0.18));\n}\n\n/* Coluna da Direita (Estatísticas) */\n.stats-column {\n    flex-grow: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    overflow-y: auto;\n    min-width: 0;\n    justify-content: space-around;\n    padding-right: 4px;\n}\n\n/* Scrollbar */\n.stats-column::-webkit-scrollbar {\n    width: 8px;\n}\n\n.stats-column::-webkit-scrollbar-track {\n    background: rgba(255, 255, 255, 0.03);\n    border-radius: 10px;\n}\n\n.stats-column::-webkit-scrollbar-thumb {\n    background: rgba(126, 166, 255, 0.25);\n    border-radius: 10px;\n}\n\n.stats-column::-webkit-scrollbar-thumb:hover {\n    background: rgba(126, 166, 255, 0.40);\n}\n\n/* Cada item de estatística */\n.stat-item {\n    background: linear-gradient(180deg, rgba(255, 255, 255, 0.025) 0%, rgba(255, 255, 255, 0.015) 100%);\n    border: 1px solid rgba(120, 170, 255, 0.10);\n    border-radius: 10px;\n    padding: 12px 20px;\n    display: flex;\n    align-items: center;\n    gap: 15px;\n    backdrop-filter: blur(4px);\n    box-shadow:\n        inset 0 1px 0 rgba(255, 255, 255, 0.03),\n        0 0 10px rgba(0, 0, 0, 0.15);\n    transition: all 0.2s ease;\n}\n\n.stat-item:hover {\n    border-color: rgba(120, 170, 255, 0.20);\n    box-shadow:\n        inset 0 1px 0 rgba(255, 255, 255, 0.04),\n        0 0 14px rgba(0, 140, 255, 0.08);\n}\n\n.stat-icon {\n    font-size: 1.8em;\n    width: 35px;\n    text-align: center;\n    flex-shrink: 0;\n}\n\n.stat-text {\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    flex-grow: 1;\n}\n\n.stat-label {\n    font-size: 0.78em;\n    color: #8ea4c7;\n    text-transform: uppercase;\n    letter-spacing: 0.6px;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    margin-bottom: 4px;\n}\n\n.stat-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 1.35em;\n    font-weight: 700;\n    color: #ffffff;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n/* Cores específicas */\n.icon-agent-up { color: #2ecc71; }\n.icon-agent-down { color: #e74c3c; }\n.icon-processes { color: #4da3ff; }\n.icon-users { color: #b57cff; }\n.icon-uptime { color: #2dd4bf; }\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto;\n    font-size: 1em;\n    color: #9fb2d1;\n    padding: 20px;\n}\n\n/* Responsividade */\n@media (max-width: 768px) {\n    .main-content-wrapper {\n        flex-direction: column;\n    }\n\n    .logo-column {\n        flex-basis: auto;\n        min-height: 120px;\n    }\n\n    .logo-column img {\n        max-height: 110px;\n    }\n}",

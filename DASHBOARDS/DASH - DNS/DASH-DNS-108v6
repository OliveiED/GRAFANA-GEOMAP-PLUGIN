        "html": "<div class=\"bar-card\">\n  <div class=\"bar-header\">\n    <div>\n      <div class=\"bar-title\">Top 10 domínios últimos 5 min</div>\n      <div class=\"bar-subtitle\">Distribuição por domínio consultado</div>\n    </div>\n    <div class=\"bar-pill\">SOC DNS</div>\n  </div>\n\n  <div class=\"bar-summary\">\n    <div class=\"summary-item\">\n      <span class=\"summary-label\">Total</span>\n      <span id=\"summary-total\" class=\"summary-value\">0</span>\n    </div>\n\n    <div class=\"summary-item\">\n      <span class=\"summary-label\">Top domínio</span>\n      <span id=\"summary-top\" class=\"summary-value\">-</span>\n    </div>\n\n    <div class=\"summary-item\">\n      <span class=\"summary-label\">Dominância</span>\n      <span id=\"summary-share\" class=\"summary-value\">0%</span>\n    </div>\n  </div>\n\n  <div class=\"bars-wrap\" id=\"bars-wrap\">\n    <div class=\"bars-empty\">Carregando dados...</div>\n  </div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "const barsWrap = htmlNode.querySelector('#bars-wrap');\nconst summaryTotal = htmlNode.querySelector('#summary-total');\nconst summaryTop = htmlNode.querySelector('#summary-top');\nconst summaryShare = htmlNode.querySelector('#summary-share');\n\nfunction escapeHtml(value) {\n  return String(value)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction formatNumber(value) {\n  return new Intl.NumberFormat('pt-BR').format(Number(value) || 0);\n}\n\nfunction getFieldByCandidates(fields, candidates) {\n  const normalizedFields = fields.map(f => ({\n    raw: f,\n    name: String(f.name || '').toLowerCase().trim()\n  }));\n\n  for (const candidate of candidates) {\n    const found = normalizedFields.find(f => f.name === candidate.toLowerCase());\n    if (found) return found.raw;\n  }\n\n  return null;\n}\n\ntry {\n  const series = htmlGraphics?.data?.series || [];\n\n  if (!series.length) {\n    barsWrap.innerHTML = '<div class=\"bars-empty\">Sem dados</div>';\n    summaryTotal.textContent = '0';\n    summaryTop.textContent = '-';\n    summaryShare.textContent = '0%';\n    return;\n  }\n\n  const frame = series[0];\n  const fields = frame.fields || [];\n\n  const fieldDominio = getFieldByCandidates(fields, [\n    'dominio',\n    'domain',\n    'destino',\n    'origem',\n    'query name',\n    'label',\n    'name',\n    'title'\n  ]);\n\n  const fieldValor = getFieldByCandidates(fields, [\n    'qut',\n    'value',\n    'valor',\n    'requisicoes',\n    'count',\n    'total',\n    'qt',\n    'quantidade'\n  ]);\n\n  if (!fieldDominio || !fieldValor) {\n    barsWrap.innerHTML = `\n      <div class=\"bars-empty\">\n        Campos não encontrados.<br><br>\n        <strong>Fields encontrados:</strong><br>\n        ${escapeHtml(fields.map(f => f.name).join(', '))}\n      </div>\n    `;\n    summaryTotal.textContent = '0';\n    summaryTop.textContent = '-';\n    summaryShare.textContent = '0%';\n    return;\n  }\n\n  const dominios = Array.from(fieldDominio.values || []).map(v => String(v ?? ''));\n  const valores = Array.from(fieldValor.values || []).map(v => Number(v) || 0);\n\n  if (!dominios.length || !valores.length) {\n    barsWrap.innerHTML = '<div class=\"bars-empty\">Sem registros</div>';\n    summaryTotal.textContent = '0';\n    summaryTop.textContent = '-';\n    summaryShare.textContent = '0%';\n    return;\n  }\n\n  const rows = dominios.map((dominio, i) => ({\n    dominio,\n    valor: valores[i] || 0\n  }));\n\n  const filteredRows = rows.filter(r => r.dominio && r.valor >= 0);\n\n  if (!filteredRows.length) {\n    barsWrap.innerHTML = '<div class=\"bars-empty\">Sem registros válidos</div>';\n    summaryTotal.textContent = '0';\n    summaryTop.textContent = '-';\n    summaryShare.textContent = '0%';\n    return;\n  }\n\n  const total = filteredRows.reduce((acc, row) => acc + row.valor, 0);\n  const maxValue = Math.max(...filteredRows.map(r => r.valor), 1);\n\n  const topRow = filteredRows.reduce((prev, curr) => {\n    return curr.valor > prev.valor ? curr : prev;\n  }, filteredRows[0]);\n\n  const dominance = total > 0 ? (topRow.valor / total) * 100 : 0;\n\n  summaryTotal.textContent = formatNumber(total);\n  summaryTop.textContent = escapeHtml(topRow.dominio);\n  summaryShare.textContent = `${dominance.toFixed(1)}%`;\n\n  let rowsHtml = '';\n\n  filteredRows.forEach((row, i) => {\n    const dominio = escapeHtml(row.dominio);\n    const valor = row.valor;\n    const percentOfMax = maxValue > 0 ? (valor / maxValue) * 100 : 0;\n    const percentOfTotal = total > 0 ? (valor / total) * 100 : 0;\n\n    let rankClass = '';\n    let fillClass = '';\n\n    if (i === 0) {\n      rankClass = 'top1';\n      fillClass = 'top1';\n    } else if (i === 1) {\n      rankClass = 'top2';\n      fillClass = 'top2';\n    } else if (i === 2) {\n      rankClass = 'top3';\n      fillClass = 'top3';\n    }\n\n    const safeWidth = valor > 0 ? Math.max(percentOfMax, 1.5) : 0;\n\n    rowsHtml += `\n      <div class=\"bar-row\">\n        <div class=\"bar-rank ${rankClass}\">#${i + 1}</div>\n        <div class=\"bar-domain\" title=\"${dominio}\">${dominio}</div>\n        <div class=\"bar-track\">\n          <div class=\"bar-fill ${fillClass}\" style=\"width:${safeWidth}%;\"></div>\n        </div>\n        <div class=\"bar-value\">${formatNumber(valor)}</div>\n        <div class=\"bar-percent\">${percentOfTotal.toFixed(1)}%</div>\n      </div>\n    `;\n  });\n\n  barsWrap.innerHTML = rowsHtml;\n\n} catch (error) {\n  const msg = error && error.message ? error.message : 'Erro desconhecido';\n  barsWrap.innerHTML = `<div class=\"bars-empty\">Erro ao renderizar: ${escapeHtml(msg)}</div>`;\n  summaryTotal.textContent = '0';\n  summaryTop.textContent = '-';\n  summaryShare.textContent = '0%';\n}",

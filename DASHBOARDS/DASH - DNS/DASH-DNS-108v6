        "html": "<div class=\"dns-card\">\n  <div class=\"dns-header\">\n    <div>\n      <div class=\"dns-title\">Top tipos últimos 5 min</div>\n      <div class=\"dns-subtitle\">Distribuição por tipo de consulta DNS</div>\n    </div>\n    <div class=\"dns-pill\">SOC DNS</div>\n  </div>\n\n  <div class=\"dns-content\">\n    <div class=\"chart-area\">\n      <svg id=\"dns-donut\" viewBox=\"0 0 420 420\" class=\"donut-svg\">\n        <g id=\"donut-segments\"></g>\n        <circle cx=\"210\" cy=\"210\" r=\"92\" class=\"donut-inner-ring\"></circle>\n\n        <text x=\"210\" y=\"192\" text-anchor=\"middle\" class=\"center-label\">Total</text>\n        <text x=\"210\" y=\"225\" text-anchor=\"middle\" id=\"center-total\" class=\"center-value\">0</text>\n        <text x=\"210\" y=\"252\" text-anchor=\"middle\" id=\"center-share\" class=\"center-share\">0%</text>\n      </svg>\n    </div>\n\n    <div class=\"legend-area\">\n      <div class=\"legend-header\">\n        <span>Tipo</span>\n        <span>Valor</span>\n        <span>%</span>\n      </div>\n      <div id=\"legend-list\" class=\"legend-list\">\n        <div class=\"legend-empty\">Carregando dados...</div>\n      </div>\n    </div>\n  </div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "const segmentsGroup = htmlNode.querySelector('#donut-segments');\nconst legendList = htmlNode.querySelector('#legend-list');\nconst centerTotal = htmlNode.querySelector('#center-total');\nconst centerShare = htmlNode.querySelector('#center-share');\n\nfunction escapeHtml(value) {\n  return String(value)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction formatNumber(value) {\n  return new Intl.NumberFormat('pt-BR').format(Number(value));\n}\n\nfunction polarToCartesian(cx, cy, r, angleDeg) {\n  const angleRad = ((angleDeg - 90) * Math.PI) / 180.0;\n  return {\n    x: cx + r * Math.cos(angleRad),\n    y: cy + r * Math.sin(angleRad)\n  };\n}\n\nfunction describeArc(cx, cy, r, startAngle, endAngle) {\n  const start = polarToCartesian(cx, cy, r, endAngle);\n  const end = polarToCartesian(cx, cy, r, startAngle);\n  const largeArcFlag = endAngle - startAngle <= 180 ? '0' : '1';\n\n  return [\n    'M', start.x, start.y,\n    'A', r, r, 0, largeArcFlag, 0, end.x, end.y\n  ].join(' ');\n}\n\nfunction getFieldByCandidates(fields, candidates) {\n  const normalized = fields.map(f => ({\n    field: f,\n    name: String(f.name || '').toLowerCase().trim()\n  }));\n\n  for (const candidate of candidates) {\n    const found = normalized.find(f => f.name === candidate.toLowerCase());\n    if (found) return found.field;\n  }\n\n  return null;\n}\n\nconst palette = [\n  '#22c55e',\n  '#3b82f6',\n  '#06b6d4',\n  '#f59e0b',\n  '#ef4444',\n  '#8b5cf6',\n  '#ec4899',\n  '#94a3b8',\n  '#10b981',\n  '#f97316',\n  '#14b8a6',\n  '#6366f1'\n];\n\ntry {\n  const series = htmlGraphics.data.series;\n\n  if (!series || !series.length) {\n    segmentsGroup.innerHTML = '';\n    legendList.innerHTML = '<div class=\"legend-empty\">Sem dados</div>';\n    centerTotal.textContent = '0';\n    centerShare.textContent = '0%';\n    return;\n  }\n\n  const frame = series[0];\n  const fields = frame.fields || [];\n\n  console.log('Fields disponíveis:', fields.map(f => f.name));\n\n  const fieldTipo = getFieldByCandidates(fields, [\n    'tipo',\n    'tipos',\n    'type',\n    'query_type',\n    'record_type',\n    'dominio',\n    'domain',\n    'title'\n  ]);\n\n  const fieldValor = getFieldByCandidates(fields, [\n    'value',\n    'valor',\n    'requisicoes',\n    'count',\n    'total',\n    'qut',\n    'qt',\n    'quantidade'\n  ]);\n\n  if (!fieldTipo || !fieldValor) {\n    segmentsGroup.innerHTML = '';\n    legendList.innerHTML = `\n      <div class=\"legend-empty\">\n        Campos de tipo e valor não encontrados<br><br>\n        Fields encontrados: ${escapeHtml(fields.map(f => f.name).join(', '))}\n      </div>\n    `;\n    centerTotal.textContent = '0';\n    centerShare.textContent = '0%';\n    return;\n  }\n\n  const labels = Array.from(fieldTipo.values || []);\n  const values = Array.from(fieldValor.values || []).map(v => Number(v) || 0);\n\n  if (!labels.length || !values.length) {\n    segmentsGroup.innerHTML = '';\n    legendList.innerHTML = '<div class=\"legend-empty\">Sem registros</div>';\n    centerTotal.textContent = '0';\n    centerShare.textContent = '0%';\n    return;\n  }\n\n  const total = values.reduce((acc, v) => acc + v, 0);\n  const maxValue = Math.max(...values, 0);\n  const maxIndex = values.findIndex(v => v === maxValue);\n  const dominantShare = total > 0 ? (maxValue / total) * 100 : 0;\n\n  centerTotal.textContent = formatNumber(total);\n  centerShare.textContent = labels[maxIndex]\n    ? `${labels[maxIndex]} • ${dominantShare.toFixed(1)}%`\n    : '0%';\n\n  const cx = 210;\n  const cy = 210;\n  const radius = 128;\n\n  let currentAngle = 0;\n  let segmentHtml = '';\n\n  segmentHtml += `<circle class=\"donut-track\" cx=\"${cx}\" cy=\"${cy}\" r=\"${radius}\"></circle>`;\n\n  for (let i = 0; i < labels.length; i++) {\n    const label = labels[i];\n    const value = values[i];\n    const pct = total > 0 ? (value / total) * 100 : 0;\n    const angle = total > 0 ? (value / total) * 360 : 0;\n    const color = palette[i % palette.length];\n\n    const startAngle = currentAngle;\n    const endAngle = currentAngle + Math.max(angle, value > 0 ? 1.2 : 0);\n\n    const path = describeArc(cx, cy, radius, startAngle, endAngle);\n\n    segmentHtml += `\n      <path\n        class=\"donut-segment\"\n        d=\"${path}\"\n        stroke=\"${color}\"\n        data-label=\"${escapeHtml(label)}\"\n        data-value=\"${value}\"\n        data-percent=\"${pct.toFixed(1)}\"\n      ></path>\n    `;\n\n    currentAngle += angle;\n  }\n\n  segmentsGroup.innerHTML = segmentHtml;\n\n  let legendHtml = '';\n\n  for (let i = 0; i < labels.length; i++) {\n    const label = escapeHtml(labels[i]);\n    const value = values[i];\n    const pct = total > 0 ? (value / total) * 100 : 0;\n    const color = palette[i % palette.length];\n\n    legendHtml += `\n      <div class=\"legend-row\">\n        <div class=\"legend-left\">\n          <span class=\"legend-dot\" style=\"background:${color};\"></span>\n          <span class=\"legend-name\">${label}</span>\n        </div>\n        <div class=\"legend-value\">${formatNumber(value)}</div>\n        <div class=\"legend-percent\">${pct.toFixed(1)}%</div>\n      </div>\n    `;\n  }\n\n  legendList.innerHTML = legendHtml;\n\n} catch (error) {\n  const msg = error && error.message ? error.message : 'Erro desconhecido';\n  segmentsGroup.innerHTML = '';\n  legendList.innerHTML = `<div class=\"legend-empty\">Erro ao renderizar: ${escapeHtml(msg)}</div>`;\n  centerTotal.textContent = '0';\n  centerShare.textContent = '0%';\n}",

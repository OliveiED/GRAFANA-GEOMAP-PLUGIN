        "html": "<div class=\"soc-panel\">\n  <div class=\"soc-header\">\n    <div>\n      <div class=\"soc-title\">Top 10 Sources</div>\n      <div class=\"soc-subtitle\">Últimos 5 minutos • DNS requests overview</div>\n    </div>\n    <div class=\"soc-pill\">SOC MONITORING</div>\n  </div>\n\n  <div class=\"soc-table-wrap\">\n    <table class=\"soc-table\">\n      <thead>\n        <tr>\n          <th class=\"col-rank\">Rank</th>\n          <th class=\"col-source\">Origens</th>\n          <th class=\"col-req\">Requisições</th>\n        </tr>\n      </thead>\n      <tbody id=\"tbody-origens\">\n        <tr>\n          <td colspan=\"3\" class=\"loading-cell\">Carregando dados...</td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "const tbody = htmlNode.querySelector('#tbody-origens');\n\nfunction formatNumber(value) {\n  return new Intl.NumberFormat('pt-BR').format(Number(value));\n}\n\nfunction getIPIcon(ip) {\n  return String(ip).includes(':') ? '🧬' : '🌐';\n}\n\nfunction escapeHtml(value) {\n  return String(value)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction getFieldByName(fields, targetName) {\n  const normalized = targetName.toLowerCase();\n  return fields.find(f => String(f.name).toLowerCase() === normalized);\n}\n\ntry {\n  const series = htmlGraphics.data.series;\n\n  if (!series || !series.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-cell\">Sem dados</td></tr>';\n    return;\n  }\n\n  const frame = series[0];\n  const fields = frame.fields || [];\n\n  const fieldOrigens = getFieldByName(fields, 'origens');\n  const fieldRequisicoes = getFieldByName(fields, 'requisicoes');\n\n  if (!fieldOrigens || !fieldRequisicoes) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"error-cell\">Campos \"origens\" e \"requisicoes\" não encontrados</td></tr>';\n    return;\n  }\n\n  const origens = Array.from(fieldOrigens.values || []);\n  const requisicoes = Array.from(fieldRequisicoes.values || []).map(v => Number(v) || 0);\n\n  if (!origens.length || !requisicoes.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-cell\">Sem registros</td></tr>';\n    return;\n  }\n\n  const maxReq = Math.max(...requisicoes, 1);\n\n  let rows = '';\n\n  for (let i = 0; i < origens.length; i++) {\n    const origemRaw = origens[i];\n    const origem = escapeHtml(origemRaw);\n    const req = requisicoes[i];\n    const percent = (req / maxReq) * 100;\n    const widthPercent = Math.max(percent, req > 0 ? 1.2 : 0);\n    const displayPercent = percent < 0.1 && req > 0 ? '<0.1%' : `${percent.toFixed(1)}%`;\n    const icon = getIPIcon(origemRaw);\n\n    let rowClass = '';\n    let badgeClass = '';\n    let barClass = '';\n\n    if (i === 0) {\n      rowClass = 'top1-row';\n      badgeClass = 'top1';\n      barClass = 'top1';\n    } else if (i === 1) {\n      rowClass = 'top2-row';\n      badgeClass = 'top2';\n      barClass = 'top2';\n    } else if (i === 2) {\n      rowClass = 'top3-row';\n      badgeClass = 'top3';\n      barClass = 'top3';\n    }\n\n    rows += `\n      <tr class=\"${rowClass}\">\n        <td>\n          <div class=\"rank-wrap\">\n            <span class=\"rank-badge ${badgeClass}\">#${i + 1}</span>\n            <span class=\"rank-dot\"></span>\n          </div>\n        </td>\n        <td>\n          <div class=\"source-wrap\">\n            <span class=\"source-icon\">${icon}</span>\n            <span class=\"source-text\">${origem}</span>\n          </div>\n        </td>\n        <td class=\"req-cell\">\n          <div class=\"req-wrap\">\n            <div class=\"req-top\">\n              <span class=\"req-value\">${formatNumber(req)}</span>\n              <span class=\"req-percent\">${displayPercent}</span>\n            </div>\n            <div class=\"req-bar\">\n              <div class=\"req-bar-fill ${barClass}\" style=\"width:${widthPercent}%;\"></div>\n            </div>\n          </div>\n        </td>\n      </tr>\n    `;\n  }\n\n  tbody.innerHTML = rows;\n\n} catch (error) {\n  const msg = error && error.message ? error.message : 'Erro desconhecido';\n  tbody.innerHTML = `<tr><td colspan=\"3\" class=\"error-cell\">Erro ao renderizar: ${escapeHtml(msg)}</td></tr>`;\n}",

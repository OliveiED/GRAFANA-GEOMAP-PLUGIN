        "onRender": "const tbody = htmlNode.querySelector('#tbody-destinos');\n\nfunction formatNumber(value) {\n  return new Intl.NumberFormat('pt-BR').format(Number(value) || 0);\n}\n\nfunction getIPIcon(ip) {\n  return String(ip).includes(':') ? '🧬' : '🎯';\n}\n\nfunction escapeHtml(value) {\n  return String(value)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction getFieldByCandidates(fields, candidates) {\n  const normalizedFields = fields.map(f => ({\n    raw: f,\n    name: String(f.name || '').toLowerCase().trim()\n  }));\n\n  for (const candidate of candidates) {\n    const found = normalizedFields.find(f => f.name === candidate.toLowerCase());\n    if (found) return found.raw;\n  }\n\n  return null;\n}\n\ntry {\n  const series = htmlGraphics?.data?.series || [];\n\n  if (!series.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-cell\">Sem dados</td></tr>';\n    return;\n  }\n\n  const frame = series[0];\n  const fields = frame.fields || [];\n\n  const fieldDestinos = getFieldByCandidates(fields, [\n    'destinos',\n    'destino',\n    'destination',\n    'query name',\n    'name',\n    'label',\n    'source'\n  ]);\n\n  const fieldRequisicoes = getFieldByCandidates(fields, [\n    'requisicoes',\n    'requisições',\n    'count',\n    'total',\n    'value',\n    'valor',\n    'quantidade',\n    'qt'\n  ]);\n\n  if (!fieldDestinos || !fieldRequisicoes) {\n    tbody.innerHTML = `\n      <tr>\n        <td colspan=\"3\" class=\"error-cell\">\n          Campos não encontrados.<br><br>\n          Fields encontrados: ${escapeHtml(fields.map(f => f.name).join(', '))}\n        </td>\n      </tr>\n    `;\n    return;\n  }\n\n  const destinos = Array.from(fieldDestinos.values || []).map(v => String(v ?? ''));\n  const requisicoes = Array.from(fieldRequisicoes.values || []).map(v => Number(v) || 0);\n\n  if (!destinos.length || !requisicoes.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-cell\">Sem registros</td></tr>';\n    return;\n  }\n\n  const rowsData = destinos.map((destino, i) => ({\n    destino,\n    req: requisicoes[i] || 0\n  })).filter(item => item.destino);\n\n  if (!rowsData.length) {\n    tbody.innerHTML = '<tr><td colspan=\"3\" class=\"empty-cell\">Sem registros válidos</td></tr>';\n    return;\n  }\n\n  const maxReq = Math.max(...rowsData.map(r => r.req), 1);\n\n  let rows = '';\n\n  rowsData.forEach((item, i) => {\n    const destinoRaw = item.destino;\n    const destino = escapeHtml(destinoRaw);\n    const req = item.req;\n\n    const percent = maxReq > 0 ? (req / maxReq) * 100 : 0;\n    const widthPercent = req > 0 ? Math.max(percent, 1.2) : 0;\n    const displayPercent = percent < 0.1 && req > 0 ? '&lt;0.1%' : `${percent.toFixed(1)}%`;\n    const icon = getIPIcon(destinoRaw);\n\n    let rowClass = '';\n    let badgeClass = '';\n    let barClass = '';\n\n    if (i === 0) {\n      rowClass = 'top1-row';\n      badgeClass = 'top1';\n      barClass = 'top1';\n    } else if (i === 1) {\n      rowClass = 'top2-row';\n      badgeClass = 'top2';\n      barClass = 'top2';\n    } else if (i === 2) {\n      rowClass = 'top3-row';\n      badgeClass = 'top3';\n      barClass = 'top3';\n    }\n\n    rows += `\n      <tr class=\"${rowClass}\">\n        <td>\n          <div class=\"rank-wrap\">\n            <span class=\"rank-badge ${badgeClass}\">#${i + 1}</span>\n            <span class=\"rank-dot\"></span>\n          </div>\n        </td>\n        <td>\n          <div class=\"source-wrap\">\n            <span class=\"source-icon\">${icon}</span>\n            <span class=\"source-text\" title=\"${destino}\">${destino}</span>\n          </div>\n        </td>\n        <td class=\"req-cell\">\n          <div class=\"req-wrap\">\n            <div class=\"req-top\">\n              <span class=\"req-value\">${formatNumber(req)}</span>\n              <span class=\"req-percent\">${displayPercent}</span>\n            </div>\n            <div class=\"req-bar\">\n              <div class=\"req-bar-fill ${barClass}\" style=\"width:${widthPercent}%;\"></div>\n            </div>\n          </div>\n        </td>\n      </tr>\n    `;\n  });\n\n  tbody.innerHTML = rows;\n\n} catch (error) {\n  const msg = error && error.message ? error.message : 'Erro desconhecido';\n  tbody.innerHTML = `\n    <tr>\n      <td colspan=\"3\" class=\"error-cell\">\n        Erro ao renderizar: ${escapeHtml(msg)}\n      </td>\n    </tr>\n  `;\n}",

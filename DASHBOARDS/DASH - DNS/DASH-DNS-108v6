        "onRender": "const root = htmlNode.querySelector('#stat-root');\n\nfunction escapeHtml(value) {\n  return String(value)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;')\n    .replace(/'/g, '&#039;');\n}\n\nfunction formatNumber(value) {\n  return new Intl.NumberFormat('pt-BR').format(Number(value) || 0);\n}\n\nfunction formatDecimal(value, digits = 1) {\n  return new Intl.NumberFormat('pt-BR', {\n    minimumFractionDigits: digits,\n    maximumFractionDigits: digits\n  }).format(Number(value) || 0);\n}\n\nfunction getFieldByCandidates(fields, candidates) {\n  const normalizedFields = fields.map(f => ({\n    raw: f,\n    name: String(f.name || '').toLowerCase().trim(),\n    type: String(f.type || '').toLowerCase().trim()\n  }));\n\n  for (const candidate of candidates) {\n    const found = normalizedFields.find(f => f.name === candidate.toLowerCase());\n    if (found) return found.raw;\n  }\n\n  return null;\n}\n\nfunction getFirstTimeField(fields) {\n  return fields.find(f => String(f.type || '').toLowerCase() === 'time') || null;\n}\n\nfunction getFirstNumericField(fields) {\n  return fields.find(f => String(f.type || '').toLowerCase() === 'number') || null;\n}\n\nfunction buildPath(points) {\n  if (!points.length) return '';\n  return points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');\n}\n\nfunction buildAreaPath(points, height) {\n  if (!points.length) return '';\n  const line = buildPath(points);\n  const first = points[0];\n  const last = points[points.length - 1];\n  return `${line} L ${last.x} ${height} L ${first.x} ${height} Z`;\n}\n\nfunction getMinMax(values) {\n  let min = Infinity;\n  let max = -Infinity;\n\n  values.forEach(v => {\n    if (v < min) min = v;\n    if (v > max) max = v;\n  });\n\n  if (!isFinite(min) || !isFinite(max)) {\n    min = 0;\n    max = 1;\n  }\n\n  if (min === max) {\n    min = min - 1;\n    max = max + 1;\n  }\n\n  return { min, max };
        "calcsMutation": "standard",
        "centerAlignContent": true,
        "codeData": "{\n  \"text\": \"Random text\"\n}",
        "css": "/* Container Principal */\n#disk-stats-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    background: #tras161B22; /* Fundo escuro sólido */\n    border-radius: 12px;\n}\n\n/* Título do Painel */\n.panel-title {\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n\n/* Grid para as estatísticas */\n.stats-grid {\n    display: grid;\n    /* 2 colunas por padrão, mas se ajusta */\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n    gap: 15px;\n    flex-grow: 1;\n    overflow-y: auto;\n}\n\n/* Cada item de estatística */\n.stat-item {\n    background: #191919;\n    border: 1px solid #30363d;\n    border-radius: 8px;\n    padding: 20px;\n    display: flex;\n    align-items: center;\n    gap: 15px;\n}\n\n.stat-icon {\n    font-size: 2em;\n    width: 40px;\n    text-align: center;\n}\n\n.stat-text {\n    display: flex;\n    flex-direction: column;\n    overflow: hidden; /* Para truncar texto se necessário */\n}\n\n.stat-label {\n    font-size: 0.85em;\n    color: #8b949e;\n    text-transform: uppercase;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n\n.stat-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 1.5em;\n    font-weight: 700;\n    color: #FFFFFF;\n    white-space: nowrap;\n}\n\n.stat-value .unit {\n    font-size: 0.6em;\n    font-weight: 400;\n    color: #8b949e;\n    margin-left: 4px;\n}\n\n/* Cores dos Ícones */\n.icon-write { color: #f39c12; }\n.icon-read { color: #3498db; }\n.icon-util { color: #9b59b6; }\n.icon-queue { color: #e74c3c; }\n.icon-wait { color: #1abc9c; }\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin-top: 20px;\n    font-size: 1em;\n    color: #8b949e;\n}",
        "dynamicData": false,
        "dynamicFieldDisplayValues": false,
        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400&display=swap\" rel=\"stylesheet\">\n\n<div id=\"disk-stats-container\"></div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#disk-stats-container');\n    if (!container) return;\n\n    // 2. Verifica se os dados estão prontos\n    if (!data.series || data.series.length === 0 || data.state !== 'Done') {\n        container.innerHTML = `<div class=\"panel-message\">Aguardando dados...</div>`;\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    if (!nameField || !valueField) {\n        container.innerHTML = `<div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div>`;\n        return;\n    }\n\n    // 3. Extrai os dados em um objeto\n    const stats = {};\n    let diskName = 'disk'; // Nome padrão\n\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i);\n        const value = valueField.values.get(i);\n        const lowerName = name.toLowerCase();\n        \n        // Pega o nome do disco (ex: \"sda\")\n        if (i === 0) {\n            diskName = name.split(':')[0];\n        }\n\n        // Mapeia os nomes dos campos para chaves do objeto\n        if (lowerName.includes('write rate')) stats.writeRate = value;\n        if (lowerName.includes('read rate')) stats.readRate = value;\n        if (lowerName.includes('utilization')) stats.utilization = value;\n        if (lowerName.includes('avgqu-sz')) stats.queueSize = value;\n        if (lowerName.includes('w_await')) stats.writeWait = value;\n        if (lowerName.includes('r_await')) stats.readWait = value;\n    }\n\n    // 4. Formata os valores\n    const f = {\n        writeRate: (stats.writeRate || 0).toFixed(3),\n        readRate: (stats.readRate || 0).toFixed(3),\n        utilization: (stats.utilization || 0).toFixed(2),\n        queueSize: (stats.queueSize || 0).toFixed(7),\n        writeWait: (stats.writeWait || 0).toFixed(2),\n        readWait: (stats.readWait || 0).toFixed(2),\n    };\n\n    // 5. Constrói o HTML\n    // --- ATUALIZAÇÃO AQUI ---\n    container.innerHTML = `\n        <h3 class=\"panel-title\">Disk I/O Status (${diskName})</h3>\n        <div class=\"stats-grid\">\n            \n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-arrow-up stat-icon icon-write\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Write Rate</div>\n                    <div class=\"stat-value\">${f.writeRate}<span class=\"unit\">w/s</span></div>\n                </div>\n            </div>\n            \n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-arrow-down stat-icon icon-read\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Read Rate</div>\n                    <div class=\"stat-value\">${f.readRate}<span class=\"unit\">r/s</span></div>\n                </div>\n            </div>\n            \n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-chart-pie stat-icon icon-util\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Disk Utilization</div>\n                    <div class=\"stat-value\">${f.utilization}<span class=\"unit\">%</span></div>\n                </div>\n            </div>\n            \n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-layer-group stat-icon icon-queue\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Avg Queue Size</div>\n                    <div class=\"stat-value\">${f.queueSize}<span class=\"unit\"></span></div>\n                </div>\n            </div>\n\n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-stopwatch stat-icon icon-wait\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Write Wait (w_await)</div>\n                    <div class=\"stat-value\">${f.writeWait}<span class=\"unit\">ms</span></div>\n                </div>\n            </div>\n            \n            <div class=\"stat-item\">\n                <i class=\"fa-solid fa-stopwatch stat-icon icon-wait\"></i>\n                <div class=\"stat-text\">\n                    <div class=\"stat-label\">Read Wait (r_await)</div>\n                    <div class=\"stat-value\">${f.readWait}<span class=\"unit\">ms</span></div>\n                </div>\n            </div>\n            \n        </div>\n    `;\n    // --- FIM DA ATUALIZAÇÃO ---\n\n})();",

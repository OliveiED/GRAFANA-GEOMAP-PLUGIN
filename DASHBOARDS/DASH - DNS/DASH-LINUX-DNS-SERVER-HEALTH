        "centerAlignContent": true,
        "codeData": "{\n  \"text\": \"Random text\"\n}",
        "css": "/* Container Principal */\n#load-avg-panel-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    padding: 20px;\n    box-sizing: border-box;\n    background: #tra161B22; /* Fundo escuro */\n    border-radius: 12px;\n    display: flex;\n    flex-direction: column;\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n.panel-title i {\n    color: #8b949e; /* Cor do ícone no título */\n    font-size: 1.2em; /* Tamanho do ícone no título */\n}\n\n/* Wrapper para os 3 blocos de estatística */\n.stats-wrapper {\n    display: flex;\n    justify-content: space-around; /* Distribui os 3 itens */\n    align-items: center;\n    flex-grow: 1; /* Ocupa o espaço vertical disponível */\n    gap: 20px;\n    padding: 10px 0;\n}\n\n/* Bloco de estatística individual (1m, 5m, 15m) */\n.stat-block {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    background: #191919; /* Fundo para cada bloco */\n    border: 1px solid #30363d;\n    border-radius: 8px;\n    padding: 15px 25px; /* Preenchimento interno */\n    flex: 1; /* Faz com que todos tenham a mesma largura */\n    max-width: 30%; /* Limita a largura para não ficarem muito grandes */\n}\n\n/* --- NOVO: Estilo para os ícones dentro de cada bloco de estatística --- */\n.stat-block .stat-icon {\n    font-size: 1.6em;\n    color: #8b949e; /* Cor padrão dos ícones nos blocos */\n    margin-bottom: 5px; /* Espaço abaixo do ícone */\n}\n\n/* Valor numérico grande */\n.stat-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 1.5em; /* Reduzido um pouco para acomodar o ícone */\n    font-weight: 700;\n    line-height: 1;\n    margin-bottom: 5px; /* Espaço abaixo do valor */\n}\n\n/* Rótulo (1 Minuto, 5 Minutos, etc.) */\n.stat-label {\n    font-size: 0.85em;\n    font-weight: 600;\n    color: #8b949e;\n    text-transform: uppercase;\n    text-align: center;\n}\n\n/* Cores para cada valor (e agora também para o ícone do bloco) */\n.stat-1m .stat-value, .stat-1m .stat-icon { color: #3498db; }  /* Azul */\n.stat-5m .stat-value, .stat-5m .stat-icon { color: #2ecc71; }  /* Verde */\n.stat-15m .stat-value, .stat-15m .stat-icon { color: #9b59b6; } /* Roxo */\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto;\n    font-size: 1em;\n    color: #8b949e;\n}\n\n/* Media queries para responsividade */\n@media (max-width: 768px) {\n    .stats-wrapper {\n        flex-direction: column; /* Empilha os blocos em telas pequenas */\n        padding: 0;\n    }\n    .stat-block {\n        max-width: 100%; /* Ocupa toda a largura disponível */\n        width: 100%;\n        padding: 10px;\n    }\n    .stat-value {\n        font-size: 2em; /* Reduz um pouco o tamanho da fonte */\n    }\n}",
        "dynamicData": false,
        "dynamicFieldDisplayValues": false,
        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n<div id=\"load-avg-panel-container\">\n    <div class=\"panel-title\">\n        <i class=\"fa-solid fa-gauge-high\"></i> <span>CPU Load Average</span>\n    </div>\n    <div class=\"stats-wrapper\">\n        </div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#load-avg-panel-container');\n    if (!container) return; // Esta checagem é importante\n\n    // 2. Verifica se os dados estão prontos\n    if (!data.series || data.series.length === 0 || data.state !== 'Done') {\n        // --- CORREÇÃO AQUI ---\n        // Constrói o HTML completo para a mensagem de \"Aguardando\"\n        container.innerHTML = `\n            <div class=\"panel-title\">\n                <i class=\"fa-solid fa-gauge-high\"></i>\n                <span>CPU Load Average</span>\n            </div>\n            <div class=\"panel-message\">Aguardando dados...</div>\n        `;\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    if (!nameField || !valueField) {\n        // --- CORREÇÃO AQUI ---\n        // Constrói o HTML completo para a mensagem de \"Erro\"\n        container.innerHTML = `\n            <div class=\"panel-title\">\n                <i class=\"fa-solid fa-gauge-high\"></i>\n                <span>CPU Load Average</span>\n            </div>\n            <div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div>\n        `;\n        return;\n    }\n\n    // 3. Extrai os dados em um objeto\n    const stats = {\n        '1m': 0,\n        '5m': 0,\n        '15m': 0\n    };\n\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i);\n        const value = valueField.values.get(i);\n\n        if (name.includes('1m avg')) stats['1m'] = value;\n        if (name.includes('5m avg')) stats['5m'] = value;\n        if (name.includes('15m avg')) stats['15m'] = value;\n    }\n\n    // 4. Formata os valores com 2 casas decimais\n    const f = {\n        '1m': (stats['1m'] || 0).toFixed(2),\n        '5m': (stats['5m'] || 0).toFixed(2),\n        '15m': (stats['15m'] || 0).toFixed(2)\n    };\n\n    // 5. Constrói o HTML final e insere no container\n    // --- CORREÇÃO AQUI ---\n    // Constrói o HTML *completo* (título + wrapper + blocos)\n    container.innerHTML = `\n        <div class=\"panel-title\">\n            <i class=\"fa-solid fa-gauge-high\"></i> \n            <span>CPU Load Average</span>\n        </div>\n        <div class=\"stats-wrapper\">\n            <div class=\"stat-block stat-1m\">\n                <i class=\"fa-solid fa-hourglass-start stat-icon\"></i>\n                <div class=\"stat-value\">${f['1m']}</div>\n                <div class=\"stat-label\">1 Min</div>\n            </div>\n            \n            <div class=\"stat-block stat-5m\">\n                <i class=\"fa-solid fa-hourglass-half stat-icon\"></i>\n                <div class=\"stat-value\">${f['5m']}</div>\n                <div class=\"stat-label\">5 Min</div>\n            </div>\n            \n            <div class=\"stat-block stat-15m\">\n                <i class=\"fa-solid fa-hourglass-end stat-icon\"></i>\n                <div class=\"stat-value\">${f['15m']}</div>\n                <div class=\"stat-label\">15 Min</div>\n            </div>\n        </div>\n    `;\n})();",

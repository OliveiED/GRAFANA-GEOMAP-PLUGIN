        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n<div id=\"disk-util-container\"></div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#disk-util-container');\n    if (!container) return;\n\n    // 2. Define a estrutura básica (título)\n    let titleHTML = `\n        <div class=\"panel-title\">\n            <i class=\"fa-solid fa-hard-drive\"></i>\n            <span>Disk Utilization</span>\n        </div>`;\n    let contentHTML = '<div class=\"disk-grid\">'; // Abre o grid\n\n    // 3. Verifica se os dados estão prontos\n    if (!data.series || data.series.length === 0 || data.state !== 'Done' || data.series[0].fields.length === 0) {\n        contentHTML += `<div class=\"panel-message\">Aguardando dados...</div>`;\n        container.innerHTML = titleHTML + contentHTML + '</div>'; // Fecha o grid\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    if (!nameField || !valueField) {\n        contentHTML += `<div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div>`;\n        container.innerHTML = titleHTML + contentHTML + '</div>'; // Fecha o grid\n        return;\n    }\n\n    // 4. Itera pelos dados e constrói o HTML para cada disco\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i); // Ex: \"sda: Disk utilization\"\n        const rawValue = valueField.values.get(i); // Ex: 0.0317 ou 10.2\n\n        // Extrai o nome do disco (ex: \"sda\")\n        const diskName = name.split(':')[0];\n\n        // --- Lógica para lidar com valores em 0-1 (0.03) ou 0-100 (10.2) ---\n        let percentage = rawValue;\n        // Se o valor for menor ou igual a 1 (e não for 0), multiplica por 100\n        if (rawValue <= 1 && rawValue > 0) { \n            percentage = rawValue * 100; // Converte 0.0317 para 3.17\n        }\n        // Se rawValue for 10.2, 'percentage' continua 10.2\n        // Se rawValue for 0, 'percentage' continua 0\n        \n        const displayPercent = percentage.toFixed(2); // Formata para 2 casas decimais\n\n        // Define a cor\n        let statusClass = 'status-ok';\n        if (percentage >= 90) {\n            statusClass = 'status-danger';\n        } else if (percentage >= 80) {\n            statusClass = 'status-warning';\n        }\n        \n        // Adiciona o HTML do item de disco\n        contentHTML += `\n            <div class=\"disk-item\">\n                <div class=\"disk-header\">\n                    <span class=\"disk-name\"><i class=\"fa-solid fa-database\"></i> ${diskName}</span>\n                    <span class=\"disk-percentage ${statusClass}\">${displayPercent}%</span>\n                </div>\n                <div class=\"disk-bar-track\">\n                    <div class=\"disk-bar-fill ${statusClass}\" style=\"width: ${percentage}%;\"></div>\n                </div>\n            </div>\n        `;\n    }\n\n    // 5. Fecha o grid e insere no container\n    contentHTML += '</div>';\n    container.innerHTML = titleHTML + contentHTML;\n\n})();",

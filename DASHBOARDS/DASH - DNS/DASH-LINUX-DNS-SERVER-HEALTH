        "css": "/* Container Principal */\n#disk-util-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    background: #wewe161B22;\n    border-radius: 12px;\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n.panel-title i {\n    color: #8b949e;\n    font-size: 1.2em;\n}\n\n/* Grid para os discos */\n.disk-grid {\n    display: flex;\n    flex-direction: column;\n    gap: 15px; /* Espaçamento entre as barras */\n    overflow-y: auto;\n    flex-grow: 1;\n}\n\n/* --- ATUALIZAÇÃO AQUI --- */\n/* Item de disco individual */\n.disk-item {\n    background: #191919;\n    border: 1px solid #30363d;\n    border-radius: 8px;\n    padding: 15px 20px;\n    \n    /* Adições para fazer o item crescer */\n    display: flex;\n    flex-direction: column;\n    justify-content: center; /* Centraliza o conteúdo verticalmente */\n    flex-grow: 1;           /* Faz o item crescer para preencher o espaço */\n    min-height: 0;          /* Necessário para flex-grow em alguns navegadores */\n}\n/* --- FIM DA ATUALIZAÇÃO --- */\n\n\n/* Cabeçalho do item (Nome + Porcentagem) */\n.disk-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 12px;\n}\n\n.disk-name {\n    font-size: 1.0em;\n    font-weight: 600;\n    color: #f9fafb;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n}\n\n.disk-percentage {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 1.2em;\n    font-weight: 700;\n}\n\n/* Barra de Progresso */\n.disk-bar-track {\n    width: 100%;\n    height: 10px; /* Barra fina */\n    background-color: #30363d;\n    border-radius: 5px;\n    overflow: hidden;\n}\n\n.disk-bar-fill {\n    height: 100%;\n    background-color: #2ecc71; /* Cor padrão */\n    border-radius: 5px;\n    transition: width 0.5s ease-out, background-color 0.3s ease;\n}\n\n/* Classes de Status (cores) */\n.status-ok { color: #2ecc71; }\n.status-warning { color: #f39c12; }\n.status-danger { color: #e74c3c; }\n\n.disk-bar-fill.status-ok { background-color: #2ecc71; }\n.disk-bar-fill.status-warning { background-color: #f39c12; }\n.disk-bar-fill.status-danger { background-color: #e74c3c; }\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto;\n    font-size: 1em;\n    color: #8b949e;\n}",
        "dynamicData": false,

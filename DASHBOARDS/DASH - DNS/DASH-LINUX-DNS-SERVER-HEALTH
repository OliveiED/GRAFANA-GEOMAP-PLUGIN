        "css": "/* Container Principal */\n#system-overview-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    background: #tras161B22; /* Fundo escuro */\n    border-radius: 12px;\n    overflow: hidden; /* Evita que o conteúdo vaze */\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n.panel-title i {\n    color: #8b949e;\n    font-size: 1.2em;\n}\n\n/* Wrapper para Layout de 2 Colunas */\n.main-content-wrapper {\n    display: flex;\n    flex-grow: 1; \n    gap: 20px;    \n    overflow: hidden; \n    min-height: 0; \n}\n\n/* Coluna da Esquerda (Logo) */\n.logo-column {\n    flex-basis: 200px; \n    flex-shrink: 0;    \n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 10px;\n}\n\n.logo-column img {\n    max-width: 100%;\n    max-height: 150px; \n    height: auto;\n    object-fit: contain; \n}\n\n/* Coluna da Direita (Estatísticas) */\n.stats-column {\n    flex-grow: 1; \n    display: flex;\n    flex-direction: column; \n    gap: 10px;            /* <-- AJUSTADO (era 15px) */\n    overflow-y: auto;     \n    min-width: 0; \n    justify-content: space-around; /* Tenta distribuir o espaço vertical */\n}\n\n/* Cada item de estatística */\n.stat-item {\n    background: #191919;\n    border: 1px solid #30363d;\n    border-radius: 8px;\n    padding: 12px 20px; /* <-- AJUSTADO (era 15px vertical) */\n    display: flex;\n    align-items: center;\n    gap: 15px;\n}\n\n.stat-icon {\n    font-size: 1.8em; \n    width: 35px;     \n    text-align: center;\n    flex-shrink: 0; \n}\n\n.stat-text {\n    display: flex;\n    flex-direction: column;\n    overflow: hidden; \n    flex-grow: 1; \n}\n\n.stat-label {\n    font-size: 0.8em; \n    color: #8b949e;\n    text-transform: uppercase;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    margin-bottom: 4px;\n}\n\n.stat-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 1.4em; \n    font-weight: 700;\n    color: #FFFFFF;\n    white-space: nowrap;\n    overflow: hidden; \n    text-overflow: ellipsis;\n}\n\n/* Cores específicas */\n.icon-agent-up { color: #2ecc71; }\n.icon-agent-down { color: #e74c3c; }\n.icon-processes { color: #3498db; }\n.icon-users { color: #9b59b6; }\n.icon-uptime { color: #1abc9c; }\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto; \n    font-size: 1em;\n    color: #8b949e;\n    padding: 20px;\n}",

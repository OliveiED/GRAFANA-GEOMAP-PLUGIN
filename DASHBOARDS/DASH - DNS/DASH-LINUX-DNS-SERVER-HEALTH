        "css": "/* Container Principal */\n#mem-icon-bar-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    background: #as161B22; /* Fundo escuro */\n    border-radius: 12px;\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n.panel-title i {\n    color: #8b949e;\n    font-size: 1.2em;\n}\n\n/* Wrapper (centraliza) */\n.content-wrapper {\n    display: flex;\n    flex-direction: column;\n    justify-content: center; /* Centraliza verticalmente */\n    align-items: center; /* Centraliza horizontalmente */\n    flex-grow: 1; /* Ocupa o espaço disponível */\n    padding: 10px 0;\n}\n\n/* Ícone Central */\n.central-icon-wrapper {\n    text-align: center;\n    margin-bottom: 20px; /* Espaço entre o ícone e o número */\n}\n\n.central-icon-wrapper i {\n    font-size: 5em; /* Tamanho do ícone grande */\n    transition: color 0.3s ease;\n}\n\n/* Texto do valor (o número grande) */\n.bar-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 3.5em; /* Tamanho grande */\n    font-weight: 700;\n    text-align: center;\n    margin-bottom: 25px; /* Espaço entre o número e a barra */\n    transition: color 0.3s ease;\n}\n\n.bar-value .percent-sign {\n    font-size: 0.5em;\n    font-weight: 400;\n    color: #8b949e;\n    margin-left: 2px;\n}\n\n/* Fundo da barra (o trilho) */\n.bar-track {\n    width: 100%;\n    max-width: 300px; /* Limita a largura da barra */\n    height: 14px;\n    background-color: #30363d;\n    border-radius: 7px;\n    overflow: hidden;\n}\n\n/* Preenchimento da barra (o progresso) */\n.bar-fill {\n    height: 100%;\n    border-radius: 7px;\n    transition: width 0.5s ease-out, background-color 0.3s ease;\n}\n\n/* Classes de Status (cores) */\n/* Cor para o ícone central e o texto do valor */\n.status-ok { color: #ffffff; }\n.status-warning { color: #f39c12; }\n.status-danger { color: #e74c3c; }\n\n/* Cor de fundo para a barra de preenchimento */\n.bar-fill.status-ok { background-color: #2ecc71; }\n.bar-fill.status-warning { background-color: #f39c12; }\n.bar-fill.status-danger { background-color: #e74c3c; }\n\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto;\n    font-size: 1em;\n    color: #8b949e;\n}",
        "dynamicData": false,

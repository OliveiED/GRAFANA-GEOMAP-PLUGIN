        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n<div id=\"mem-icon-bar-container\"></div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#mem-icon-bar-container');\n    if (!container) return;\n\n    // --- ATUALIZAÇÃO: Ícone e Título ---\n    let titleHTML = `\n        <div class=\"panel-title\">\n            <i class=\"fa-solid fa-memory\"></i>\n            <span>Memory Utilization</span>\n        </div>`;\n    let contentHTML = '';\n\n    // 2. Verifica se os dados estão prontos\n    if (!data.series || data.series.length === 0 || data.state !== 'Done') {\n        contentHTML = `<div class=\"panel-message\">Aguardando dados...</div>`;\n        container.innerHTML = titleHTML + contentHTML;\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    if (!nameField || !valueField) {\n        contentHTML = `<div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div>`;\n        container.innerHTML = titleHTML + contentHTML;\n        return;\n    }\n\n    // 3. Extrai o dado de \"Memory utilization\"\n    let rawValue = 0;\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i);\n        // --- ATUALIZAÇÃO: Procura por \"memory utilization\" ---\n        if (name.toLowerCase().includes('memory utilization')) {\n            rawValue = valueField.values.get(i);\n            break; // Encontrou, pode parar\n        }\n    }\n\n    // 4. Converte o valor e define o status\n    const percentage = rawValue; // O valor (12.3) já é a porcentagem\n    const displayValue = percentage.toFixed(2); // Formata para 2 casas (ex: \"12.30\")\n\n    let statusClass = 'status-ok';\n    if (percentage >= 90) { // Alerta de memória\n        statusClass = 'status-danger';\n    } else if (percentage >= 80) { // Aviso de memória\n        statusClass = 'status-warning';\n    }\n\n    // 5. Constrói o HTML final (com o ícone de memória)\n    contentHTML = `\n        <div class=\"content-wrapper\">\n            \n            <div class=\"central-icon-wrapper\">\n                <i class=\"fa-solid fa-memory ${statusClass}\"></i>\n            </div>\n            \n            <div class=\"bar-value ${statusClass}\">\n                ${displayValue}<span class=\"percent-sign\">%</span>\n            </div>\n            \n            <div class=\"bar-track\">\n                <div class=\"bar-fill ${statusClass}\" style=\"width: ${percentage}%;\"></div>\n            </div>\n        </div>\n    `;\n\n    container.innerHTML = titleHTML + contentHTML;\n\n})();",

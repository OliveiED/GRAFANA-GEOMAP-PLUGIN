        "css": "/* Container Principal */\n#cpu-icon-bar-container {\n    font-family: 'Inter', sans-serif;\n    color: #E0E6F1;\n    width: 100%;\n    height: 100%;\n    box-sizing: border-box;\n    display: flex;\n    flex-direction: column;\n    padding: 20px;\n    background: #dadda161B22; /* Fundo escuro */\n    border-radius: 12px;\n}\n\n/* Título do Painel */\n.panel-title {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: #c9d1d9;\n    margin: 0 0 15px 0;\n    padding-bottom: 15px;\n    border-bottom: 1px solid #30363d;\n    flex-shrink: 0;\n}\n.panel-title i {\n    color: #8b949e;\n    font-size: 1.2em;\n}\n\n/* Wrapper (centraliza) */\n.content-wrapper {\n    display: flex;\n    flex-direction: column;\n    justify-content: center; /* Centraliza verticalmente */\n    align-items: center; /* Centraliza horizontalmente */\n    flex-grow: 1; /* Ocupa o espaço disponível */\n    padding: 10px 0;\n}\n\n/* --- NOVO: Ícone Central --- */\n.central-icon-wrapper {\n    text-align: center;\n    margin-bottom: 20px; /* Espaço entre o ícone e o número */\n}\n\n.central-icon-wrapper i {\n    font-size: 5em; /* Tamanho do ícone grande */\n    transition: color 0.3s ease;\n}\n/* --- FIM DO NOVO --- */\n\n\n/* Texto do valor (o número grande) */\n.bar-value {\n    font-family: 'Roboto Mono', monospace;\n    font-size: 3.5em; /* Tamanho grande */\n    font-weight: 700;\n    text-align: center;\n    margin-bottom: 25px; /* Espaço entre o número e a barra */\n    transition: color 0.3s ease;\n}\n\n.bar-value .percent-sign {\n    font-size: 0.5em;\n    font-weight: 400;\n    color: #8b949e;\n    margin-left: 2px;\n}\n\n/* Fundo da barra (o trilho) */\n.bar-track {\n    width: 100%;\n    max-width: 300px; /* Limita a largura da barra */\n    height: 14px;\n    background-color: #30363d;\n    border-radius: 7px;\n    overflow: hidden;\n}\n\n/* Preenchimento da barra (o progresso) */\n.bar-fill {\n    height: 100%;\n    border-radius: 7px;\n    transition: width 0.5s ease-out, background-color 0.3s ease;\n}\n\n/* --- ATUALIZAÇÃO: Classes de Status (cores) --- */\n/* Cor para o ícone central e o texto do valor */\n.status-ok { color: #ffffff; }\n.status-warning { color: #f39c12; }\n.status-danger { color: #e74c3c; }\n\n/* Cor de fundo para a barra de preenchimento */\n.bar-fill.status-ok { background-color: #2ecc71; }\n.bar-fill.status-warning { background-color: #f39c12; }\n.bar-fill.status-danger { background-color: #e74c3c; }\n/* --- FIM DA ATUALIZAÇÃO --- */\n\n\n/* Mensagem de carregamento/erro */\n.panel-message {\n    text-align: center;\n    margin: auto;\n    font-size: 1em;\n    color: #8b949e;\n}",
        "dynamicData": false,
        "dynamicFieldDisplayValues": false,
        "dynamicHtmlGraphics": false,
        "dynamicProps": false,
        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Roboto+Mono:wght@400;700&display=swap\" rel=\"stylesheet\">\n\n<div id=\"cpu-icon-bar-container\"></div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#cpu-icon-bar-container');\n    if (!container) return;\n\n    // Define a estrutura básica (título)\n    let titleHTML = `\n        <div class=\"panel-title\">\n            <i class=\"fa-solid fa-microchip\"></i>\n            <span>CPU Utilization</span>\n        </div>`;\n    let contentHTML = '';\n\n    // 2. Verifica se os dados estão prontos\n    if (!data.series || data.series.length === 0 || data.state !== 'Done') {\n        contentHTML = `<div class=\"panel-message\">Aguardando dados...</div>`;\n        container.innerHTML = titleHTML + contentHTML;\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    if (!nameField || !valueField) {\n        contentHTML = `<div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div>`;\n        container.innerHTML = titleHTML + contentHTML;\n        return;\n    }\n\n    // 3. Extrai o dado de \"CPU utilization\"\n    let rawValue = 0;\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i);\n        if (name.toLowerCase().includes('cpu utilization')) {\n            rawValue = valueField.values.get(i);\n            break; // Encontrou, pode parar\n        }\n    }\n\n    // 4. Converte o valor e define o status\n    // (Usa a correção anterior: o valor já é a porcentagem)\n    const percentage = rawValue; \n    // Formata para 2 casas decimais (ex: 0.14)\n    const displayValue = percentage.toFixed(2); \n\n    let statusClass = 'status-ok';\n    if (percentage >= 90) {\n        statusClass = 'status-danger';\n    } else if (percentage >= 70) {\n        statusClass = 'status-warning';\n    }\n\n    // 5. Constrói o HTML final (com o ícone central)\n    contentHTML = `\n        <div class=\"content-wrapper\">\n            \n            <div class=\"central-icon-wrapper\">\n                <i class=\"fa-solid fa-microchip ${statusClass}\"></i>\n            </div>\n            \n            <div class=\"bar-value ${statusClass}\">\n                ${displayValue}<span class=\"percent-sign\">%</span>\n            </div>\n            \n            <div class=\"bar-track\">\n                <div class=\"bar-fill ${statusClass}\" style=\"width: ${percentage}%;\"></div>\n            </div>\n        </div>\n    `;\n\n    container.innerHTML = titleHTML + contentHTML;\n\n})();",

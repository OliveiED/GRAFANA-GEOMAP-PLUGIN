        "onRender": "(function() {\n    // 1. Encontra o container\n    const container = htmlNode.querySelector('#system-overview-container');\n    if (!container) return;\n    \n    // --- ATUALIZAÇÃO: URL da Imagem ---\n    const logoUrl = \"https://storage.googleapis.com/flowbix-img/IMG%20DASHBOARD/linux-logo-png-image-11660298434qt5f32bbxj33333333.png\";\n\n    // --- Função Auxiliar para formatar Uptime (segundos) ---\n    function formatUptime(seconds) {\n        if (isNaN(seconds) || seconds < 0) return 'N/A';\n        if (seconds === 0) return '0s';\n\n        const d = Math.floor(seconds / (3600*24));\n        const h = Math.floor(seconds % (3600*24) / 3600);\n        const m = Math.floor(seconds % 3600 / 60);\n\n        let result = '';\n        if (d > 0) result += d + 'd ';\n        if (h > 0) result += h + 'h ';\n        if (m > 0 || (d === 0 && h === 0)) result += m + 'm'; \n        \n        return result.trim();\n    }\n    // ----------------------------------------------------\n\n    // Define a estrutura básica (título)\n    let titleHTML = `\n        <div class=\"panel-title\">\n            <i class=\"fa-solid fa-server\"></i>\n            <span>System Overview</span>\n        </div>`;\n    \n    // --- ATUALIZAÇÃO: Mensagem de \"Aguardando\" usa novo layout ---\n    if (!data.series || data.series.length === 0 || data.state !== 'Done') {\n        container.innerHTML = titleHTML + `\n            <div class=\"main-content-wrapper\">\n                <div class=\"logo-column\"><img src=\"${logoUrl}\" alt=\"Linux Logo\"></div>\n                <div class=\"stats-column\"><div class=\"panel-message\">Aguardando dados...</div></div>\n            </div>`;\n        return;\n    }\n\n    const series = data.series[0];\n    const nameField = series.fields.find(f => f.name === 'Field');\n    const valueField = series.fields.find(f => f.name === 'Last *');\n\n    // --- ATUALIZAÇÃO: Mensagem de \"Erro\" usa novo layout ---\n    if (!nameField || !valueField) {\n        container.innerHTML = titleHTML + `\n            <div class=\"main-content-wrapper\">\n                <div class=\"logo-column\"><img src=\"${logoUrl}\" alt=\"Linux Logo\"></div>\n                <div class=\"stats-column\"><div class=\"panel-message\" style=\"color: #e74c3c;\">Erro: Colunas \"Field\" e \"Last *\" não encontradas.</div></div>\n            </div>`;\n        return;\n    }\n\n    // 3. Extrai os dados em um objeto\n    const stats = {\n        agentPing: null,\n        processes: null,\n        users: null,\n        uptime: null\n    };\n\n    for (let i = 0; i < nameField.values.length; i++) {\n        const name = nameField.values.get(i);\n        const value = valueField.values.get(i);\n        const lowerName = name.toLowerCase();\n\n        if (lowerName.includes('zabbix agent ping')) stats.agentPing = value;\n        if (lowerName.includes('number of processes')) stats.processes = value;\n        if (lowerName.includes('number of logged in users')) stats.users = value;\n        if (lowerName.includes('system uptime')) stats.uptime = value;\n    }\n\n    // 4. Formata os valores e define ícones/classes\n    const agentStatusText = stats.agentPing === 1 ? 'Up' : 'Down';\n    const agentStatusClass = stats.agentPing === 1 ? 'icon-agent-up' : 'icon-agent-down';\n    const agentIcon = stats.agentPing === 1 ? 'fa-circle-check' : 'fa-circle-xmark';\n    \n    const processesValue = stats.processes !== null ? stats.processes : 'N/A';\n    const usersValue = stats.users !== null ? stats.users : 'N/A';\n    const uptimeValue = stats.uptime !== null ? formatUptime(stats.uptime) : 'N/A';\n\n    // --- ATUALIZAÇÃO: Constrói o HTML para os itens de estatística ---\n    let statItemsHTML = '';\n\n    // Zabbix Agent Ping\n    statItemsHTML += `\n        <div class=\"stat-item\">\n            <i class=\"fa-solid ${agentIcon} stat-icon ${agentStatusClass}\"></i>\n            <div class=\"stat-text\">\n                <div class=\"stat-label\">Zabbix Agent</div>\n                <div class=\"stat-value\">${agentStatusText}</div>\n            </div>\n        </div>\n    `;\n\n    // Number of Processes\n    statItemsHTML += `\n        <div class=\"stat-item\">\n            <i class=\"fa-solid fa-list-check stat-icon icon-processes\"></i>\n            <div class=\"stat-text\">\n                <div class=\"stat-label\">Processes</div>\n                <div class=\"stat-value\">${processesValue}</div>\n            </div>\n        </div>\n    `;\n\n    // Number of Logged In Users\n    statItemsHTML += `\n        <div class=\"stat-item\">\n            <i class=\"fa-solid fa-users stat-icon icon-users\"></i>\n            <div class=\"stat-text\">\n                <div class=\"stat-label\">Logged In Users</div>\n                <div class=\"stat-value\">${usersValue}</div>\n            </div>\n        </div>\n    `;\n\n    // System Uptime\n    statItemsHTML += `\n        <div class=\"stat-item\">\n            <i class=\"fa-solid fa-clock stat-icon icon-uptime\"></i>\n            <div class=\"stat-text\">\n                <div class=\"stat-label\">System Uptime</div>\n                <div class=\"stat-value\">${uptimeValue}</div>\n            </div>\n        </div>\n    `;\n    // --- FIM DA CONSTRUÇÃO DOS ITENS ---\n\n\n    // --- ATUALIZAÇÃO: Constrói o HTML final com o novo layout ---\n    container.innerHTML = titleHTML + `\n        <div class=\"main-content-wrapper\">\n            <div class=\"logo-column\">\n                <img src=\"${logoUrl}\" alt=\"Linux Logo\">\n            </div>\n            <div class=\"stats-column\">\n                ${statItemsHTML} \n            </div>\n        </div>\n    `;\n    // --- FIM DA ATUALIZAÇÃO FINAL ---\n\n})();",

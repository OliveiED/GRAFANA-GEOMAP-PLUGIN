        "visualEditor": {
          "code": "const series = context.panel.data.series.map((s) => {\n  // Encontrando os campos numéricos e de tempo de cada série\n  const numberField = s.fields.find((f) => f.type === 'number');\n\n  // Acessando os valores numéricos da série\n  const sData = numberField ? (numberField.values.buffer || numberField.values) : [];\n\n  // Garantindo que existem dados para mostrar\n  if (sData.length === 0) {\n    return {}; // Retorna vazio se não houver dados\n  }\n\n  // Pegando o último valor para exibir no gráfico\n  const lastValue = sData[sData.length - 1];\n\n  return {\n    name: s.refId,\n    type: 'bar', // Usando bar para a visualização\n    data: [lastValue], // Passando o valor para o gráfico de barras\n    label: {\n      show: true, // Mostrar o valor no topo da barra\n      position: 'top', // Colocar o valor no topo da barra\n      fontSize: 20, // Tamanho da fonte\n      fontWeight: 'bold', // Peso da fonte\n      color: '#00e600', // Cor do valor\n    },\n    itemStyle: {\n      color: '#00e600', // Cor da barra\n    },\n    emphasis: {\n      label: {\n        color: '#ff9800', // Cor quando em foco\n        fontSize: 24,\n      },\n    },\n  };\n});\n\nreturn {\n  backgroundColor: 'transparent', // Fundo transparente\n  tooltip: {\n    trigger: 'item',\n    formatter: '{FIB} <br/>{b} : {c}', // Tooltip mostrando o valor\n  },\n  series: series, // Passando as séries configuradas\n  xAxis: {\n    type: 'category', // Tipo de eixo X (categorias)\n    data: context.panel.data.series.map((s) => s.refId), // Definindo o nome das categorias como os IDs das séries\n  },\n  yAxis: {\n    type: 'value', // Eixo Y (valores numéricos)\n    axisLabel: {\n      formatter: '{value}', // Formatando os valores do eixo Y\n    },\n  },\n  grid: {\n    left: '5%', // Espaçamento esquerdo\n    right: '5%', // Espaçamento direito\n    bottom: '10%', // Espaçamento inferior\n    top: '20%', // Espaçamento superior\n  },\n};\n",

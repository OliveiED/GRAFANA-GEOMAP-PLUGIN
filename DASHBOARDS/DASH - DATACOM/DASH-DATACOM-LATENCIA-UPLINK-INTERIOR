        "onRender": "const cardsContainer = htmlNode.querySelector(\"#latency-cards\");\n\nlet metrics = [];\n\n// Limpa o nome (ex: \"IA74_PKS... : ICMP response time\" -> \"IA74_PKS...\")\nfunction cleanName(rawName) {\n  if (!rawName) return \"Desconhecido\";\n  return rawName.split(':')[0].trim();\n}\n\n// 1. LEITURA DOS DADOS (Padrão Reduce do Grafana)\nif (data && data.series && data.series.length > 0) {\n  const fields = data.series[0].fields;\n  const nameField = fields.find(f => f.type === 'string'); // Coluna dos Nomes\n  const valueField = fields.find(f => f.type === 'number'); // Coluna dos Valores (Last *)\n\n  if (nameField && valueField) {\n    for (let i = 0; i < nameField.values.length; i++) {\n      let rawVal = parseFloat(valueField.values[i]);\n\n      // Converte segundos para milissegundos\n      let valMs = isNaN(rawVal) ? 0 : rawVal * 1000;\n\n      if (valMs > 0) {\n        metrics.push({\n          name: cleanName(nameField.values[i]),\n          last: valMs\n        });\n      }\n    }\n  }\n}\n\n// 2. ORDENA E PEGA O TOP 10\nmetrics.sort((a, b) => b.last - a.last);\nconst top10 = metrics.slice(0, 10);\n\n// 3. RENDERIZA OS CARDS\nfunction renderCards() {\n  if (top10.length === 0) {\n    cardsContainer.innerHTML = '<div style=\"color:#ffffff; grid-column: 1/-1; text-align:center; padding-top: 20px;\">Nenhum dado de latência encontrado.</div>';\n    return;\n  }\n\n  let cardsHtml = '';\n  top10.forEach((item) => {\n    // Card limpo, sem estilo inline de borda colorida\n    cardsHtml += `\n      <div class=\"latency-card\">\n        <span class=\"host-name\">${item.name}</span>\n        <div class=\"latency-value\">\n          ${item.last.toFixed(2)} <span class=\"ms-unit\">ms</span>\n        </div>\n      </div>\n    `;\n  });\n\n  cardsContainer.innerHTML = cardsHtml;\n}\n\nrenderCards();",

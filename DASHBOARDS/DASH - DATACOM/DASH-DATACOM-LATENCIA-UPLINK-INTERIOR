        "html": "<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css\">\n\n<div class=\"problems-dashboard-container\">\n  <!-- HEADER -->\n  <div class=\"header-container\">\n    <div class=\"panel-title\">ICMP PING STATUS</div>\n  </div>\n\n  <!-- KPI CARDS GRID -->\n  <div id=\"icmp-kpi\" class=\"kpi-grid\"></div>\n\n  <!-- TABELA DE HOSTS -->\n  <div class=\"table-wrapper\">\n    <table class=\"premium-table\">\n      <thead>\n        <tr>\n          <th data-sort=\"name\" style=\"width: 70%; text-align: left; padding-left: 20px;\">HOST\n            <i class=\"fas fa-sort sort-icon\"></i></th>\n          <th data-sort=\"status\" class=\"active-sort\" style=\"width: 30%;\">STATUS <i class=\"fas fa-sort-up sort-icon\"></i>\n          </th>\n        </tr>\n      </thead>\n      <tbody id=\"icmp-tbody\">\n        <!-- Renderizado via JS -->\n      </tbody>\n    </table>\n  </div>\n\n  <!-- CONTROLES DE PAGINAÇÃO -->\n  <div id=\"pagination-controls\" class=\"pagination-container\"></div>\n</div>",
        "onInit": "// Sets the text from customProperties\nconst htmlgraphicsText = htmlNode.getElementById('htmlgraphics-text');\n\nif (htmlgraphicsText) {\n  htmlgraphicsText.textContent = customProperties.text;\n\n  // Change the text color based on the theme\n  if (theme.isDark) {\n    htmlgraphicsText.style.color = 'green';\n  } else {\n    htmlgraphicsText.style.color = 'red';\n  }\n}\n",
        "onInitOnResize": false,
        "onRender": "const kpiContainer = htmlNode.querySelector(\"#icmp-kpi\");\nconst tbody = htmlNode.querySelector(\"#icmp-tbody\");\nconst paginationContainer = htmlNode.querySelector(\"#pagination-controls\");\nconst tableHeaders = htmlNode.querySelectorAll(\"th[data-sort]\");\n\nlet hostsList = [];\n\n// Configurações de Estado\nlet currentPage = 1;\nconst itemsPerPage = 15;\nlet currentFilter = 'all'; // Pode ser 'all', 1 (UP) ou 0 (DOWN)\nlet currentSort = { column: 'status', dir: 'asc' }; // Padrão: DOWN primeiro (0 vem antes de 1)\n\n// 1. EXTRAÇÃO DE DADOS (Baseado na tabela Field x Last *)\nif (data && data.series && data.series.length > 0) {\n  const fields = data.series[0].fields;\n\n  // Procura a coluna de nomes e a coluna de valores\n  const nameField = fields.find(f => f.type === 'string' || f.name === 'Field');\n  const valueField = fields.find(f => f.type === 'number');\n\n  if (nameField && valueField && nameField.values && valueField.values) {\n    let names = nameField.values.toArray ? nameField.values.toArray() : nameField.values;\n    let values = valueField.values.toArray ? valueField.values.toArray() : valueField.values;\n\n    for (let i = 0; i < names.length; i++) {\n      let rawName = names[i] || \"Desconhecido\";\n      let val = parseFloat(values[i]);\n\n      // Limpa a string removendo \": ICMP ping\" para deixar a tabela mais limpa\n      let cleanName = rawName.replace(/:?\\s*ICMP ping/i, '').trim();\n\n      hostsList.push({\n        name: cleanName,\n        status: (val === 1) ? 1 : 0 // 1 = UP, 0 = DOWN\n      });\n    }\n  }\n}\n\n// LÓGICA DE ORDENAÇÃO\nfunction sortHosts() {\n  hostsList.sort((a, b) => {\n    if (currentSort.column === 'default' || currentSort.dir === 'none') {\n      // Padrão: Mostra os DOWN (0) primeiro, e desempata por nome\n      if (a.status !== b.status) return a.status - b.status;\n      return a.name.localeCompare(b.name);\n    }\n\n    let valA = a[currentSort.column];\n    let valB = b[currentSort.column];\n\n    if (currentSort.column === 'name') {\n      valA = valA.toLowerCase();\n      valB = valB.toLowerCase();\n    }\n\n    if (valA < valB) return currentSort.dir === 'asc' ? -1 : 1;\n    if (valA > valB) return currentSort.dir === 'asc' ? 1 : -1;\n\n    // Desempate por nome\n    return a.name.localeCompare(b.name);\n  });\n}\n\n// EVENTOS THEAD\ntableHeaders.forEach(th => {\n  th.addEventListener('click', () => {\n    const clickedCol = th.getAttribute('data-sort');\n    const isTextCol = (clickedCol === 'name');\n    const defaultFirstDir = isTextCol ? 'asc' : 'asc'; // Para status, ASC mostra DOWN(0) primeiro.\n\n    if (currentSort.column === clickedCol) {\n      if (currentSort.dir === defaultFirstDir) {\n        currentSort.dir = defaultFirstDir === 'asc' ? 'desc' : 'asc';\n      } else {\n        currentSort.column = 'default';\n        currentSort.dir = 'none';\n      }\n    } else {\n      currentSort.column = clickedCol;\n      currentSort.dir = defaultFirstDir;\n    }\n\n    tableHeaders.forEach(el => {\n      el.classList.remove('active-sort');\n      el.querySelector('.sort-icon').className = 'fas fa-sort sort-icon';\n    });\n\n    if (currentSort.column !== 'default') {\n      th.classList.add('active-sort');\n      const iconClass = currentSort.dir === 'asc' ? 'fas fa-sort-up' : 'fas fa-sort-down';\n      th.querySelector('.sort-icon').className = `${iconClass} sort-icon`;\n    }\n\n    currentPage = 1;\n    sortHosts();\n    renderTable();\n  });\n});\n\n// RENDERIZAÇÃO CARDS\nfunction renderKPIs() {\n  let countTotal = hostsList.length;\n  let countUp = hostsList.filter(h => h.status === 1).length;\n  let countDown = hostsList.filter(h => h.status === 0).length;\n\n  const getInactiveClass = (filterVal) => (currentFilter !== 'all' && currentFilter !== filterVal) ? 'inactive-filter' : '';\n\n  let html = `\n    <!-- TOTAL -->\n    <div class=\"problem-card ${getInactiveClass('all')}\" data-filter=\"all\">\n      <div class=\"card-title\">TOTAL HOSTS</div>\n      <div class=\"card-value\">${countTotal}</div>\n    </div>\n    \n    <!-- UP -->\n    <div class=\"problem-card ${getInactiveClass(1)}\" data-filter=\"1\" style=\"border-bottom: 3px solid #73BF69;\">\n      <div class=\"card-title\"><i class=\"fas fa-arrow-up\" style=\"color:#73BF69\"></i> ONLINE</div>\n      <div class=\"card-value\">${countUp}</div>\n    </div>\n\n    <!-- DOWN -->\n    <div class=\"problem-card ${getInactiveClass(0)}\" data-filter=\"0\" style=\"border-bottom: 3px solid #E02F44;\">\n      <div class=\"card-title\"><i class=\"fas fa-arrow-down\" style=\"color:#E02F44\"></i> OFFLINE</div>\n      <div class=\"card-value\">${countDown}</div>\n    </div>\n  `;\n\n  kpiContainer.innerHTML = html;\n\n  const generatedCards = kpiContainer.querySelectorAll('.problem-card');\n  generatedCards.forEach(card => {\n    card.addEventListener('click', () => {\n      let filterVal = card.getAttribute('data-filter');\n      if (filterVal !== 'all') filterVal = parseInt(filterVal);\n\n      if (currentFilter === filterVal) { currentFilter = 'all'; }\n      else { currentFilter = filterVal; }\n\n      currentPage = 1;\n      renderKPIs();\n      renderTable();\n    });\n  });\n}\n\n// RENDERIZAÇÃO TABELA\nfunction renderTable() {\n  let filteredList = hostsList;\n  if (currentFilter !== 'all') {\n    filteredList = hostsList.filter(h => h.status === currentFilter);\n  }\n\n  if (filteredList.length === 0) {\n    tbody.innerHTML = '<tr><td colspan=\"2\" style=\"text-align:center; padding: 40px; color: #ffffff;\">Nenhum host encontrado para este filtro.</td></tr>';\n    paginationContainer.innerHTML = '';\n    return;\n  }\n\n  const totalPages = Math.ceil(filteredList.length / itemsPerPage);\n  if (currentPage > totalPages) currentPage = totalPages;\n  if (currentPage < 1) currentPage = 1;\n\n  const startIdx = (currentPage - 1) * itemsPerPage;\n  const paginatedList = filteredList.slice(startIdx, startIdx + itemsPerPage);\n\n  let tableHtml = '';\n\n  paginatedList.forEach(h => {\n    let isUp = h.status === 1;\n    let statusClass = isUp ? \"status-up\" : \"status-down\";\n    let statusText = isUp ? \"UP\" : \"DOWN\";\n\n    tableHtml += `\n      <tr>\n        <td style=\"text-align: left; padding-left: 20px;\">${h.name}</td>\n        <td><span class=\"sev-badge ${statusClass}\">${statusText}</span></td>\n      </tr>\n    `;\n  });\n\n  tbody.innerHTML = tableHtml;\n\n  paginationContainer.innerHTML = `\n    <button class=\"page-btn\" id=\"btn-prev\" ${currentPage === 1 ? 'disabled' : ''}>\n      <i class=\"fas fa-chevron-left\"></i> Previous\n    </button>\n    <div class=\"page-info\">Page ${currentPage} of ${totalPages}</div>\n    <button class=\"page-btn\" id=\"btn-next\" ${currentPage === totalPages ? 'disabled' : ''}>\n      Next <i class=\"fas fa-chevron-right\"></i>\n    </button>\n  `;\n\n  const btnPrev = htmlNode.querySelector(\"#btn-prev\");\n  const btnNext = htmlNode.querySelector(\"#btn-next\");\n\n  if (btnPrev) btnPrev.addEventListener('click', () => { currentPage--; renderTable(); });\n  if (btnNext) btnNext.addEventListener('click', () => { currentPage++; renderTable(); });\n}\n\n// INICIALIZAÇÃO\ntableHeaders.forEach(el => {\n  el.classList.remove('active-sort');\n  el.querySelector('.sort-icon').className = 'fas fa-sort sort-icon';\n});\n\nsortHosts();\nrenderKPIs();\nrenderTable();",

          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(ocorrencias_4360 + ocorrencias_4370) AS total\r\nFROM (\r\n    SELECT ht.hostid, ht.host, \r\n           (LENGTH(ht.host) - LENGTH(REPLACE(ht.host, '4360', ''))) / LENGTH('4360') AS ocorrencias_4360,\r\n           (LENGTH(ht.host) - LENGTH(REPLACE(ht.host, '4370', ''))) / LENGTH('4370') AS ocorrencias_4370\r\n    FROM hosts ht\r\n    INNER JOIN hosts_groups hg ON (hg.hostid = ht.hostid)\r\n    INNER JOIN hstgrp g ON (g.groupid = hg.groupid)\r\n    INNER JOIN items it ON (it.hostid = ht.hostid)\r\n    WHERE (ht.host LIKE '%4360%' OR ht.host LIKE '%4370%')\r\n    AND g.name IN ($grupos)\r\n    AND it.key_ = 'icmpping'\r\n) AS subquery;",

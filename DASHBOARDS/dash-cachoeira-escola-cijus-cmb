          "code": "// Inicializar arrays para armazenar os dados das séries e os rótulos de tempo\nconst seriesData = [];\nlet timeLabels = [];\n\n// Função para gerar uma cor aleatória\nfunction getRandomColor() {\n  const letters = '0123456789ABCDEF';\n  let color = '#';\n  for (let i = 0; i < 6; i++) {\n    color += letters[Math.floor(Math.random() * 16)];\n  }\n  return color;\n}\n\n// Função para formatar o valor com a unidade correta\nfunction formatDataValue(value) {\n  if (value >= 1e9) {\n    return { value: (value / 1e9).toFixed(2), unit: 'GB' };\n  } else if (value >= 1e6) {\n    return { value: (value / 1e6).toFixed(2), unit: 'MB' };\n  } else if (value >= 1e3) {\n    return { value: (value / 1e3).toFixed(2), unit: 'KB' };\n  } else {\n    return { value: value.toFixed(2), unit: 'B' };\n  }\n}\n\n// Função para formatação dos rótulos do eixo Y com unidades\nfunction formatYAxisLabel(value) {\n  const formatted = formatDataValue(value);\n  return `${formatted.value} ${formatted.unit}`;\n}\n\n// Função para obter a unidade mais comum\nfunction getCommonUnit(series) {\n  return 'GB';\n}\n\n// Iterar pelos frames de dados do Grafana\ncontext.panel.data.series.forEach((series, seriesIndex) => {\n  const timeField = series.fields.find((field) => field.type === 'time');\n  const valueFields = series.fields.filter((field) => field.type === 'number');\n\n  valueFields.forEach((valueField, valueIndex) => {\n    const seriesName = valueField.config.displayNameFromDS || valueField.name || `Series ${seriesIndex + 1}.${valueIndex + 1}`;\n    const data = valueField.values.map(d => parseFloat(d));\n\n    if (timeLabels.length === 0 && timeField) {\n      timeLabels = timeField.values.map(time => new Date(time).toLocaleTimeString());\n    }\n\n    // Gerar uma cor aleatória para a linha e o preenchimento\n    const color = getRandomColor();\n\n    seriesData.push({\n      name: seriesName,\n      type: 'line',\n      smooth: true,\n      lineStyle: {\n        width: 2,\n        color: color // Cor da linha\n      },\n      showSymbol: false,\n      areaStyle: {\n        opacity: 0.2,\n        color: color // Cor do preenchimento (mesma cor da linha)\n      },\n      emphasis: {\n        focus: 'series'\n      },\n      data: data\n    });\n  });\n});\n\nconst commonUnit = getCommonUnit(seriesData);\n\nreturn {\n  color: seriesData.map(() => getRandomColor()),\n  tooltip: {\n    trigger: 'axis',\n    axisPointer: {\n      type: 'cross',\n      label: {\n        backgroundColor: '#6a7985'\n      }\n    },\n    formatter: function (params) {\n      let tooltipText = '';\n      params.forEach(param => {\n        const seriesName = param.seriesName;\n        const dataIndex = param.dataIndex;\n        const data = seriesData.find(s => s.name === seriesName).data[dataIndex];\n        const formatted = formatDataValue(data);\n        tooltipText += `${seriesName}: ${formatted.value} ${formatted.unit}<br/>`;\n      });\n      return tooltipText;\n    }\n  },\n  legend: {\n    data: seriesData.map(s => s.name),\n    textStyle: {\n      color: '#fff',\n      fontSize: 14\n    },\n    itemWidth: 20,\n    itemHeight: 14\n  },\n  toolbox: {\n    orient: 'vertical',\n    left: 'right',\n    top: 'center',\n    feature: {\n      saveAsImage: {}\n    }\n  },\n  grid: {\n    left: '5%',\n    right: '5%',\n    bottom: '5%',\n    containLabel: true\n  },\n  xAxis: [{\n    type: 'category',\n    boundaryGap: false,\n    data: timeLabels,\n    axisLine: {\n      lineStyle: {\n        color: '#fff',\n        width: 2\n      }\n    },\n    axisLabel: {\n      textStyle: {\n        color: '#fff',\n        fontSize: 12\n      }\n    },\n    splitLine: {\n      show: false\n    }\n  }],\n  yAxis: [{\n    type: 'value',\n    axisLine: {\n      lineStyle: {\n        color: '#fff',\n        width: 2\n      }\n    },\n    axisLabel: {\n      formatter: formatYAxisLabel,\n      textStyle: {\n        color: '#fff',\n        fontSize: 14\n      }\n    },\n    splitLine: {\n      show: true,\n      lineStyle: {\n        color: '#444',\n        type: 'dashed'\n      }\n    }\n  }],\n  series: seriesData,\n  backgroundColor: 'transparent', // Cor de fundo escura\n  title: {\n    text: 'Análise de Uso de Banda',\n    left: 'center',\n    top: '20px',\n    textStyle: {\n      color: '#fff',\n      fontSize: 0\n    }\n  },\n  animationDuration: 1500, // Animação suave\n  animationEasing: 'elasticOut' // Efeito de animação\n};\n",

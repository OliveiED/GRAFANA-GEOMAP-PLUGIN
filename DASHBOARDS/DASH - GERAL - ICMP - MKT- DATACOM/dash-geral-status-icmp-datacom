          "rawQuery": true,
          "rawSql": "SELECT \r\n    (SELECT COUNT(DISTINCT ht.hostid)\r\n     FROM items it\r\n     INNER JOIN hosts ht ON it.hostid = ht.hostid\r\n     INNER JOIN hosts_groups hg ON (hg.hostid = ht.hostid)\r\n     INNER JOIN hstgrp g ON (g.groupid = hg.groupid)\r\n     WHERE it.key_ = 'icmpping' AND ht.status = 0 AND g.name IN ($grupos)) AS total,\r\n    (SELECT COUNT(DISTINCT ht.hostid)\r\n     FROM items it\r\n     INNER JOIN hosts ht ON it.hostid = ht.hostid\r\n     INNER JOIN hosts_groups hg ON (hg.hostid = ht.hostid)\r\n     INNER JOIN hstgrp g ON (g.groupid = hg.groupid)\r\n     LEFT JOIN (\r\n         SELECT itemid, MAX(clock) AS max_clock \r\n         FROM history_uint \r\n         WHERE clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}\r\n         GROUP BY itemid\r\n     ) max_hu ON max_hu.itemid = it.itemid\r\n     LEFT JOIN history_uint hu ON hu.itemid = max_hu.itemid AND hu.clock = max_hu.max_clock\r\n     WHERE it.key_ = 'icmpping' AND ht.status = 0 AND g.name IN ($grupos) AND hu.value = 1 AND clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}) AS Onlines,\r\n    (SELECT COUNT(DISTINCT ht.hostid)\r\n     FROM items it\r\n     INNER JOIN hosts ht ON it.hostid = ht.hostid\r\n     INNER JOIN hosts_groups hg ON (hg.hostid = ht.hostid)\r\n     INNER JOIN hstgrp g ON (g.groupid = hg.groupid)\r\n     LEFT JOIN (\r\n         SELECT itemid, MAX(clock) AS max_clock \r\n         FROM history_uint \r\n         WHERE clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}\r\n         GROUP BY itemid\r\n     ) max_hu ON max_hu.itemid = it.itemid\r\n     LEFT JOIN history_uint hu ON hu.itemid = max_hu.itemid AND hu.clock = max_hu.max_clock\r\n     WHERE it.key_ = 'icmpping' AND ht.status = 0 AND g.name IN ($grupos) AND hu.value = 0 AND clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}) AS Offlines;\r\n",

          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT \r\n    ht.hostid AS 'HOSTID',\r\n    ht.name AS 'HOST',\r\n    CASE \r\n        WHEN i.ip <> '' THEN i.ip \r\n        ELSE i.dns \r\n    END AS 'IP/DNS',\r\n    CONCAT(ROUND(hu.value * 1000, 2), ' ms') AS \"TEMPO RESPOSTA\",\r\n    CONVERT_TZ(from_unixtime(hu.clock), '+00:00', '+03:00') AS \"HORA MEDIDA\"\r\nFROM items it\r\nINNER JOIN hosts ht ON it.hostid = ht.hostid\r\nINNER JOIN hosts_groups hg ON hg.hostid = ht.hostid\r\nINNER JOIN hstgrp g ON g.groupid = hg.groupid\r\nINNER JOIN interface i ON i.hostid = it.hostid\r\nLEFT JOIN (\r\n    SELECT itemid, MAX(clock) AS max_clock \r\n    FROM history \r\n    WHERE clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}\r\n    GROUP BY itemid\r\n) max_hu ON max_hu.itemid = it.itemid\r\nLEFT JOIN history hu ON hu.itemid = max_hu.itemid AND hu.clock = max_hu.max_clock\r\nWHERE it.key_ = 'icmppingsec'\r\n    AND ht.status = 0\r\n    AND hu.value IS NOT NULL\r\n    AND g.name IN ($grupos)\r\n    AND hu.clock BETWEEN ${__from:date:seconds} AND ${__to:date:seconds}\r\n    AND it.name = 'ICMP response time';\r\n",
